{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove",
  "version": "0.7.1",
  "identifier": "com.gaoxin.grove",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grove",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1460,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
